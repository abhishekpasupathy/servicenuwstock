APP_NAME=DadStock API
APP_ENV=development
API_PREFIX=/api

# Local development only. In production, set this to your deployed Vercel URL.
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
SQLITE_PATH=./data/dadstock.sqlite
CACHE_TTL_SECONDS=300
MARKET_CACHE_TTL_SECONDS=1800
MARKET_FALLBACK_CACHE_TTL_SECONDS=600

# Optional free realtime feeds. Alpaca IEX is preferred; Finnhub is secondary.
ALPACA_API_KEY=your_key_here
ALPACA_API_SECRET=your_secret_here
FINNHUB_API_KEY=your_finnhub_key_here
